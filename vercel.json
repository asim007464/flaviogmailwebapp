{
  "env": {
    "CAMPAIGN_DATA_DIR": "/tmp/flavioemail-data"
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/src/server.js" }],
  "functions": {
    "src/server.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/campaign/cron",
      "schedule": "*/5 * * * *"
    }
  ]
}
