# Hostinger Business Email (hPanel → Emails → Connect Apps & Devices)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=kontakt@six-point-o.ch
SMTP_PASS=your-mailbox-password

FROM_NAME=6.0 · six-point-o.ch
FROM_EMAIL=kontakt@six-point-o.ch
REPLY_TO=kontakt@six-point-o.ch

# Optional defaults for the template
CTA_URL=https://www.six-point-o.ch/dashboard/mathe-2?topic=1.1
PRICING_URL=https://www.six-point-o.ch/pricing
UNSUBSCRIBE_URL=https://www.six-point-o.ch/unsubscribe
OFFER_UNTIL=23.5

# Web app — public URL for logo in preview (production)
APP_URL=http://localhost:3000
LOGO_URL=
PORT=3000
SEND_DELAY_MS=3000
DAILY_SEND_LIMIT=5000

# Login (change in production)
AUTH_USER=superflavio
AUTH_PASSWORD=change-me
SESSION_SECRET=use-a-long-random-string

# Scheduled bulk send: 20 emails, then wait 1 hour, repeat
BATCH_SIZE=20
BATCH_INTERVAL_MS=3600000

# Vercel (required on live): writable folder for campaign queue
CAMPAIGN_DATA_DIR=/tmp/flavioemail-data
